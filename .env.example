# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Environment ───────────────────────────────────────────────────────────────
# Controls which Telegram bot token is active.
# "dev"  → uses TEST_BOT_TOKEN  (local development with test bot + ngrok)
# "prod" → uses PROD_BOT_TOKEN  (live server with production bot)
BOT_ENV=dev

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=spambotcontrol
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/spambotcontrol

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Telegram bots ─────────────────────────────────────────────────────────────
# Test bot token — get from @BotFather, used only in dev/local environment.
TEST_BOT_TOKEN=1234567890:AABBtest_bot_token_here

# Production bot token — get from @BotFather, used only in prod environment.
PROD_BOT_TOKEN=9876543210:AABBprod_bot_token_here

# Bot username (without @) — used to build referral deep-links.
# Find it: @BotFather → /mybots → select bot → Bot Settings → username
TELEGRAM_BOT_USERNAME=yourbotusername

# Webhook secret — sent by Telegram in X-Telegram-Bot-Api-Secret-Token header.
# Must match the value used when the webhook was registered.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-token

# Full public HTTPS URL where Telegram delivers updates (must include path).
# Dev:  set after ngrok starts (handled automatically by make dev)
# Prod: https://<VPS_IP>/bot/webhook/
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/bot/webhook/

# ── Production: VPS deployment ────────────────────────────────────────────────
# Your VPS public IP address. Used by scripts/prod_up.sh to:
#   - generate a self-signed SSL certificate (CN=<VPS_IP>)
#   - build the webhook URL: https://<VPS_IP>/bot/webhook/
# Leave empty in dev (not used).
VPS_IP=45.135.164.155

# Prod-specific Django settings:
# DEBUG=False
# ALLOWED_HOSTS=45.135.164.155
# SECRET_KEY=<long-random-string>

# ── Channel subscription gate ─────────────────────────────────────────────────
# Channel users must subscribe to before using the bot. Admins bypass this.
# Leave empty to disable the gate entirely.
#
# Public channel  → use @username:       @grmly
# Private channel → use numeric ID:      -1001234567890
#
# The bot must be an admin of the channel for getChatMember to work.
SUBSCRIPTION_CHANNEL_ID=@grmly

# Link shown to non-subscribed users in the inline "Subscribe" button.
SUBSCRIPTION_CHANNEL_URL=https://t.me/grmly

# ── ngrok (dev only) ──────────────────────────────────────────────────────────
# Required when running docker-compose.ngrok.yml overlay.
# Get your token: https://dashboard.ngrok.com/get-started/your-authtoken
# Not used in prod.
NGROK_AUTHTOKEN=your-ngrok-authtoken-here

# Static ngrok domain (without https://).
# Get a free static domain: dashboard.ngrok.com → Domains → + New Domain
# Then set it once in BotFather: /setdomain → select bot → paste the domain.
# With a static domain the BotFather setup is one-time only.
NGROK_DOMAIN=your-static-domain.ngrok-free.app
