# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Environment ───────────────────────────────────────────────────────────────
# Controls which Telegram bot token is active.
# "dev"  → uses TEST_BOT_TOKEN  (local development with test bot + ngrok)
# "prod" → uses PROD_BOT_TOKEN  (live server with production bot)
BOT_ENV=dev

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=spambotcontrol
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/spambotcontrol

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Telegram bots ─────────────────────────────────────────────────────────────
# Test bot token — get from @BotFather, used only in dev/local environment.
TEST_BOT_TOKEN=1234567890:AABBtest_bot_token_here

# Production bot token — get from @BotFather, used only in prod environment.
PROD_BOT_TOKEN=9876543210:AABBprod_bot_token_here

# Bot username (without @) — used to build referral deep-links.
TELEGRAM_BOT_USERNAME=yourbotusername

# Webhook secret — sent by Telegram in X-Telegram-Bot-Api-Secret-Token header.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-token

# Full public HTTPS URL where Telegram delivers updates (must include path).
# Dev:  set automatically by make dev (ngrok)
# Prod: https://gramly.tech/bot/webhook/
TELEGRAM_WEBHOOK_URL=https://gramly.tech/bot/webhook/

# ── Production: domain deployment ─────────────────────────────────────────────
# Primary domain for the production server.
# scripts/prod_up.sh uses this to:
#   - obtain Let's Encrypt SSL certificate
#   - build the webhook URL: https://<DOMAIN>/bot/webhook/
#   - set Django ALLOWED_HOSTS and CSRF_TRUSTED_ORIGINS
# Leave empty in dev (not used).
DOMAIN=gramly.tech

# Email for Let's Encrypt certificate notifications (optional but recommended).
# If empty, cert is obtained without email (--register-unsafely-without-email).
CERTBOT_EMAIL=admin@gramly.tech

# Prod-specific Django settings (override for production .env):
# DEBUG=False
# ALLOWED_HOSTS=gramly.tech,www.gramly.tech
# SECRET_KEY=<long-random-string>

# ── Channel subscription gate ─────────────────────────────────────────────────
# Channel users must subscribe to before using the bot. Admins bypass this.
# Leave empty to disable the gate entirely.
SUBSCRIPTION_CHANNEL_ID=@gramlyspam
SUBSCRIPTION_CHANNEL_URL=https://t.me/gramlyspam

# ── File storage (CRM screenshots and media uploads) ──────────────────────────
# S3-compatible storage is MANDATORY — there is no local filesystem fallback.
# All environments (dev and prod) require these variables to be set.
#
# ── Dev (MinIO — local Docker container, auto-started by make dev) ────────────
# MinIO runs as a Docker service and is started automatically.
# MinIO API:     http://localhost:9000  (S3 endpoint)
# MinIO Console: http://localhost:9001  (web UI — browse files, manage buckets)
#
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=spambotcontrol
# Dev: MinIO container hostname (internal Docker DNS)
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=auto
# Dev: false — MinIO bucket is public-read, no signed URLs needed
MEDIA_QUERYSTRING_AUTH=false
MEDIA_QUERYSTRING_EXPIRE=3600
# Dev: rewrite internal Docker URL (minio:9000) to browser-accessible URL
MEDIA_S3_PUBLIC_URL=http://localhost:9000

# ── Prod (Cloudflare R2 / AWS S3) ────────────────────────────────────────────
# Uncomment and replace with actual prod values:
# AWS_ACCESS_KEY_ID=your-r2-or-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-r2-or-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=spambotcontrol-prod
# For Cloudflare R2: AWS_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# For AWS S3:        leave AWS_S3_ENDPOINT_URL unset (or omit entirely)
# AWS_S3_REGION_NAME=auto
# Prod: true — private bucket, signed URLs with 1-hour TTL
# MEDIA_QUERYSTRING_AUTH=true
# MEDIA_QUERYSTRING_EXPIRE=3600
# Prod: leave empty — boto3 URLs point directly to the bucket endpoint
# MEDIA_S3_PUBLIC_URL=

# ── ngrok (dev only) ──────────────────────────────────────────────────────────
NGROK_AUTHTOKEN=your-ngrok-authtoken-here
NGROK_DOMAIN=your-static-domain.ngrok-free.app
